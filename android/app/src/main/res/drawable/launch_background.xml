    <item android:drawable="@color/launch_background" />

    <item
        android:width="280dp"
        android:height="280dp"
        android:gravity="center">
        <bitmap
            android:gravity="fill"
            android:src="@drawable/splash_icon" />
    </item>
</layer-list>
